#!/bin/sh

fn_get_available_tun_interface() {
    local existing=$(ip -o link show | awk -F': ' '{print $2}' | grep '^opkgtun[0-9]*$')

    if [ -z "$existing" ]; then
        echo "opkgtun0"
        return 0
    fi

    local max=$(echo "$existing" | sed 's/opkgtun//' | sort -n | tail -1)
    local next=$((max + 1))

    echo "opkgtun$next"
}

fn_get_available_ip() {
    local subnet="172.16.1"
    local start=100
    local end=200

    for i in $(seq $start $end); do
        local ip="$subnet.$i"

        if ! grep -q "$ip" /proc/net/arp 2>/dev/null &&
            ! ping -c 1 -W 1 "$ip" >/dev/null 2>&1; then
            echo "$ip"
            return 0
        fi
    done

    return 1
}

fn_convert_to_ndm_name() {
    echo "$1" | sed 's/^opkg/Opkg/; s/tun/Tun/'
}

# $1 - ndm command
# $2 - error message
fn_ndm_cmd() {
    local out
    out=$(/bin/ndmc -c "$1" 2>&1 >/dev/null) || {
        echo "$2:"
        echo "| $out" >&2
        return 1
    }
}

# $1 - ndm interface
fn_ndm_if_create() {
    fn_ndm_cmd \
        "interface $1" \
        "Failed to create interface $1"
}

# $1 - ndm interface
fn_ndm_if_remove() {
    fn_ndm_cmd \
        "no interface $1" \
        "Failed to remove interface $1"
}

# $1 - ndm interface
# $2 - ip
# $3 - netmask
fn_ndm_if_set_address() {
    fn_ndm_cmd \
        "interface $1 ip address $2 $3" \
        "Failed to set ip/netmask for interface $1"
    # local out
    # out=$(/bin/ndmc -c "interface $1 ip address $2 $3" 2>&1 >/dev/null) || {
    #     echo "Failed to set ip/netmask for interface $1:"
    #     echo "| $out" >&2
    #     return 1
    # }
}

# $1 - ndm interface
# $2 - description
fn_ndm_if_set_description() {
    fn_ndm_cmd \
        "interface $1 description $2" \
        "Failed to set description for interface $1"
}

# $1 - ndm interface
fn_ndm_if_up() {
    fn_ndm_cmd \
        "interface $1 up" \
        "Failed to up interface $1"
}

# $1 - ndm interface
fn_ndm_if_down() {
    fn_ndm_cmd \
        "interface $1 down" \
        "Failed to down interface $1"
}

# $1 - ndm interface
fn_ndm_if_exists() {
    ndmc -c "show interface" 2>/dev/null | grep -q "$1"
}

fn_ndm_save_system_config() {
    fn_ndm_cmd \
        "system configuration save" \
        "Failed to save system config"
}

fn_load_tun_interface_config() {
    if [ -z "$IFACE" ]; then
        if [ -n "$RESERVED_IFACE" ]; then
            IFACE="$RESERVED_IFACE"
        else
            IFACE=$(fn_get_available_tun_interface)
        fi
    fi

    if [ -z "$IFACE_IP" ]; then
        if [ -n "$RESERVED_IFACE_IP" ]; then
            IFACE_IP="$RESERVED_IFACE_IP"
        else
            IFACE_IP=$(fn_get_available_ip)
        fi
    fi

    if [ -z "$IFACE_MASK" ]; then
        if [ -n "$RESERVED_IFACE_MASK" ]; then
            IFACE_MASK="$RESERVED_IFACE_MASK"
        else
            IFACE_MASK="255.255.255.255"
        fi
    fi

    if [ -z "$IFACE_NAME" ]; then
        if [ -n "$RESERVED_IFACE_NAME" ]; then
            IFACE_NAME="$RESERVED_IFACE_NAME"
        else
            IFACE_NAME="usque"
        fi
    fi
}

fn_create_tun_interface() {
    echo "Create tun interface $IFACE: $IFACE_IP $IFACE_MASK"
    local iface=$(fn_convert_to_ndm_name "$IFACE")

    if fn_ndm_if_exists "$iface"; then
        fn_ndm_if_remove "$iface"
    fi

    fn_ndm_if_create "$iface" || return 1
    fn_ndm_if_set_description "$iface" "$IFACE_NAME" || return 1

    fn_ndm_cmd \
        "interface $iface ip global auto" \
        "Failed to perform 'ip global auto'" || return 1

    fn_ndm_cmd \
        "interface $iface ip tcp adjust-mss pmtu" \
        "Failed to set perform 'ip tcp adjust-mss pmtu'" || return 1

    fn_ndm_if_set_address "$iface" "$IFACE_IP" "$IFACE_MASK" || return 1

    fn_ndm_cmd \
        "interface $iface ip mtu 1280" \
        "Failed to set MTU" || return 1

    # fn_ndm_if_up "$iface"
    # fn_ndm_save_system_config
}

fn_remove_tun_interface() {
    echo "Remove tun interface $RESERVED_IFACE"
    local iface=$(fn_convert_to_ndm_name "$RESERVED_IFACE")

    # fn_ndm_if_down "$iface"
    fn_ndm_if_remove "$iface"
    # fn_ndm_save_system_config
}

fn_up_tun_interface() {
    if [ -z "$RESERVED_IFACE" ]; then
        echo "No reserved interface to work with"
        return 1
    fi

    echo "Up tun interface $RESERVED_IFACE"
    local iface=$(fn_convert_to_ndm_name "$RESERVED_IFACE")

    fn_ndm_if_up "$iface"
    # fn_ndm_save_system_config
}

fn_down_tun_interface() {
    if [ -z "$RESERVED_IFACE" ]; then
        echo "No reserved interface to work with"
        return 1
    fi

    echo "Down tun interface $RESERVED_IFACE"
    local iface=$(fn_convert_to_ndm_name "$RESERVED_IFACE")

    fn_ndm_if_down "$iface"
    # fn_ndm_save_system_config
}

fn_acquire_tun_interface() {
    echo "Resolve interface credentials..."
    fn_load_tun_interface_config || return 1

    local changed=0

    if [ "$IFACE" != "$RESERVED_IFACE" ]; then
        if [ -n "$RESERVED_IFACE" ]; then
            echo "Acquired interface $RESERVED_IFACE changed to $IFACE"
            echo "Remove old acquired interface $RESERVED_IFACE"
            local reserved_iface=$(fn_convert_to_ndm_name "$RESERVED_IFACE")
            fn_ndm_if_remove "$reserved_iface"
        fi

        # create new interface
        fn_create_tun_interface || return 1
        changed=1
    else
        local iface=$(fn_convert_to_ndm_name "$IFACE")

        if [ -n "$RESERVED_IFACE_IP" ] && [ "$IFACE_IP" != "$RESERVED_IFACE_IP" ]; then
            echo "IP address $RESERVED_IFACE_IP changed to $IFACE_IP"
            changed=1
        fi

        if [ -n "$RESERVED_IFACE_MASK" ] && [ "$IFACE_MASK" != "$RESERVED_IFACE_MASK" ]; then
            echo "Netmask $RESERVED_IFACE_MASK changed to $IFACE_MASK"
            changed=1
        fi

        if [ -n "$RESERVED_IFACE_NAME" ] && [ "$IFACE_NAME" != "$RESERVED_IFACE_NAME" ]; then
            echo "Interface name $RESERVED_IFACE_NAME changed to $IFACE_NAME"
            fn_ndm_if_set_description "$iface" "$IFACE_NAME"
            changed=1
        fi

        if [ "$changed" -eq 1 ]; then
            fn_ndm_if_set_address "$iface" "$IFACE_IP" "$IFACE_MASK" || return 1
        fi
    fi

    if [ "$changed" -eq 1 ]; then
        RESERVED_IFACE="$IFACE"
        fn_create_reserved_config
        fn_ndm_save_system_config
    fi
}

fn_release_tun_interface() {
    if [ -z "$RESERVED_IFACE" ]; then
        echo "No reserved interface to work with"
        return 1
    fi

    fn_remove_tun_interface
    fn_remove_reserved_config
    fn_ndm_save_system_config
}
